<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="@dimen/padding_standard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/padding_standard">

        <ImageView
            android:id="@+id/iv_elder_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/elder_avatar_desc"
            android:src="@drawable/ic_elder_avatar" />

        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_standard"
        android:layout_marginTop="8dp"
        android:text="@string/today_meds_title"
        android:textColor="@color/primary"
        android:textSize="@dimen/text_body"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_empty_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="@string/empty_med_list"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body"
        android:visibility="gone" />

    <ListView
        android:id="@+id/lv_medications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_health_log"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:backgroundTint="@null"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_health_log"
            android:textColor="@color/white"
            android:textSize="@dimen/text_button" />

        <Button
            android:id="@+id/btn_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/button_shape"
            android:backgroundTint="@null"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_history"
            android:textColor="@color/white"
            android:textSize="@dimen/text_button" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_add_med"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/button_shape"
        android:backgroundTint="@null"
        android:minHeight="@dimen/button_min_height"
        android:text="@string/btn_add_med"
        android:textColor="@color/white"
        android:textSize="@dimen/text_button" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/button_shape_dark"
            android:backgroundTint="@null"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_settings"
            android:textColor="@color/white"
            android:textSize="@dimen/text_button" />

        <Button
            android:id="@+id/btn_emergency"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/button_shape_emergency"
            android:backgroundTint="@null"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_emergency"
            android:textColor="@color/white"
            android:textSize="@dimen/text_button" />

    </LinearLayout>

</LinearLayout>
